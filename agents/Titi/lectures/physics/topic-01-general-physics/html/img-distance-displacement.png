        <style>
    #topAd {
        padding-bottom: 10px;
    }

    /* Makes buttons not transparent, swaps 48 pixel with 3 px margin to 51 pixel with 3 px padding so no transparent strip on margin */
    .adhesion_wrapper .adhesion_buttons {
        background-color: white;
        margin-left: 0 !important;
        padding-left: 3px;
        width: 51px;
    }

    #adhesion_mobile_wrapper,
    #adhesion_tablet_wrapper,
    #adhesion_desktop_wrapper {
        background-color: transparent !important;
    }

    #adhesion_desktop {
        background-color: white;
    }

    #universalPlayer_wrapper {
        bottom: 65px;
        position: absolute !important;
    }

    body.adhesion {
        padding-bottom: 0 !important;
    }

    /* Ensures Right ad is visible and can still display 728x90 (1148-365-728-51 (the "x" on right)) > 0), also gives room for bottom nav */
    @media screen and (min-width: 950px) {
        #adhesion_mobile_wrapper, #adhesion_tablet_wrapper, #adhesion_desktop_wrapper {
            justify-content: start !important;
            background-color: transparent !important;
        }
    }

    @media screen and (min-width: 1148px) {
        #fixed_container_bottom {
            right: 365px;
            width: calc(100vw - 365px) !important;
        }

        #universalPlayer_wrapper {
            right: -350px;
        }

        #adhesion_mobile_wrapper,
        #adhesion_tablet_wrapper,
        #adhesion_desktop_wrapper {
            justify-content: center !important;
        }
    }
</style>


